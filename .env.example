# Set to "false" to require real login (signup + username/password).
# Any other value (or unset) auto-approves all requests as a shared dev user — local dev only.
AUTO_APPROVE_AUTH=false

# API key for external tools. Required on all API requests via x-api-key header.
# For local-only use the default is dev-key-local-only (no .env needed).
SHOPPER_API_KEY=your-secret-key

# GitHub personal access token for feedback → GitHub Issues integration.
# Needs repo scope (or public_repo for public repos).
GITHUB_TOKEN=your-github-token
